# ============================================================
# Environment variables — copy this file to .env and fill in
# ============================================================

# ── Airflow ──────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# Any random string
AIRFLOW_SECRET_KEY=

# ── Azure ADLS ───────────────────────────────────────────────
# From Azure portal → Storage account → Access keys
# Required for Kafka consumers, Spark jobs, and dbt to access bronze/silver layers
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# ── ENTSO-E API ──────────────────────────────────────────────
# Register at https://transparency.entsoe.eu and request an API key
ENTSOE_API_KEY=

# ── Superset ─────────────────────────────────────────────────
# Any random string
SUPERSET_SECRET_KEY=
